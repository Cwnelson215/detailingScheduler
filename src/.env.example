# detailing app — environment variables
#
# In dev, leave DB_* unset to use the embedded PGlite database at src/pglite-data/.
# In production, set DB_* to point at the shared Postgres cluster.

# --- database (production only) ---
DB_HOST=
DB_PORT=5432
DB_NAME=detailing
DB_USER=detailing
DB_PASSWORD=
# When DB_HOST is set, the pg Pool uses TLS by default (rejectUnauthorized=true).
# Set to "false" when connecting to the in-cluster CloudNativePG instance, which
# serves a self-signed cert. Leave unset for managed Postgres providers (RDS,
# Neon, Supabase, etc.) whose certs chain to a public CA.
DB_SSL_REJECT_UNAUTHORIZED=

# --- next-auth ---
# Required in production. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# The fully-qualified URL where the app is reachable (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# --- email (Resend) ---
# If unset, booking confirmation emails are skipped (logged only). Required in prod.
RESEND_API_KEY=
# Verified sender on Resend (e.g., "Nelson Detailing <booking@detailing.cwnel.com>").
# The domain part must be verified in Resend. If unset, falls back to
# onboarding@resend.dev for local testing.
EMAIL_FROM=
# Optional Reply-To for the customer confirmation. Set this to an address that
# actually receives mail (e.g. a Cloudflare Email Routing address that forwards
# to your inbox, like bookings@cwnel.com) when the EMAIL_FROM domain has no
# inbox. If unset, replies go to the EMAIL_FROM address.
EMAIL_REPLY_TO=
# Business address that gets a notification on every new booking (e.g. the
# owner's inbox). If unset, owner notifications are skipped (logged only).
BOOKING_NOTIFY_EMAIL=
